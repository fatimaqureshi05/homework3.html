	document.getElementById("sliderLabel").innerHTML = "5 out of 10";
}


// ---- Review button: shows all the entered info below the form ----

function showReview() {
	var html = "<h3>Review Your Information</h3>";
	html += "<table border='1' cellpadding='5'>";

	html += "<tr><td><b>First Name</b></td><td>" + document.getElementById("firstName").value + "</td></tr>";
	html += "<tr><td><b>Middle Initial</b></td><td>" + document.getElementById("mi").value + "</td></tr>";
	html += "<tr><td><b>Last Name</b></td><td>" + document.getElementById("lastName").value + "</td></tr>";
	html += "<tr><td><b>Date of Birth</b></td><td>" + document.getElementById("dob").value + "</td></tr>";

	// mask the SSN, only show last 4
	var ssn = document.getElementById("ssn").value;
	var maskedSSN = "***-**-" + ssn.substring(ssn.length - 4);
	html += "<tr><td><b>SSN</b></td><td>" + maskedSSN + "</td></tr>";

	html += "<tr><td><b>Email</b></td><td>" + document.getElementById("email").value + "</td></tr>";
	html += "<tr><td><b>Phone</b></td><td>" + document.getElementById("phone").value + "</td></tr>";
	html += "<tr><td><b>Address Line 1</b></td><td>" + document.getElementById("addr1").value + "</td></tr>";
	html += "<tr><td><b>Address Line 2</b></td><td>" + document.getElementById("addr2").value + "</td></tr>";
	html += "<tr><td><b>City</b></td><td>" + document.getElementById("city").value + "</td></tr>";
	html += "<tr><td><b>State</b></td><td>" + document.getElementById("state").value + "</td></tr>";
	html += "<tr><td><b>Zip</b></td><td>" + document.getElementById("zip").value + "</td></tr>";

	// get all checked conditions
	var checkboxes = document.querySelectorAll("input[name='conditions']:checked");
	var conditions = "";
	for (var i = 0; i < checkboxes.length; i++) {
		conditions += checkboxes[i].value;
		if (i < checkboxes.length - 1) {
			conditions += ", ";
		}
	}
	if (conditions == "") conditions = "None selected";
	html += "<tr><td><b>Conditions</b></td><td>" + conditions + "</td></tr>";

	// get selected radio buttons
	var gender = document.querySelector("input[name='g']:checked");
	html += "<tr><td><b>Gender</b></td><td>" + (gender ? gender.value : "Not selected") + "</td></tr>";

	var vaccinated = document.querySelector("input[name='v']:checked");
	html += "<tr><td><b>Vaccinated?</b></td><td>" + (vaccinated ? vaccinated.value : "Not selected") + "</td></tr>";

	var insurance = document.querySelector("input[name='i']:checked");
	html += "<tr><td><b>Insurance?</b></td><td>" + (insurance ? insurance.value : "Not selected") + "</td></tr>";

	html += "<tr><td><b>Health Score</b></td><td>" + document.getElementById("healthScore").value + " out of 10</td></tr>";
	html += "<tr><td><b>Symptoms/Notes</b></td><td>" + document.getElementById("symptoms").value + "</td></tr>";
	html += "<tr><td><b>User ID</b></td><td>" + document.getElementById("userID").value + "</td></tr>";
	html += "<tr><td><b>Password</b></td><td>********</td></tr>";

	html += "</table>";

	var panel = document.getElementById("reviewPanel");
	panel.innerHTML = html;
	panel.style.display = "block";
}
